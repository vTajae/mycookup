{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*",
    "index.html"
  ],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "react": ["@preact/compat"],
      "react-dom": ["@preact/compat"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true
  }
}
