{
	"name": "frontend",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"dev": "vite --host",
		"dev:https": "vite --host",
		"preview": "vite preview",
		"typecheck": "tsc -b",
		"cap:build": "npm run build && npx cap sync",
		"cap:ios": "npm run cap:build && npx cap open ios",
		"cap:android": "npm run cap:build && npx cap open android",
		"cap:serve": "npm run cap:build && npx cap run ios --livereload --external",
		"cap:serve:android": "npm run cap:build && npx cap run android --livereload --external",
		"deploy:static": "npm run build && echo 'Static build ready for deployment in ./build directory'",
		"serve:local": "npm run build && npx serve build",
		"deploy:pages": "npm run cap:build && npx wrangler pages deploy build",
		"deploy:pages:preview": "npm run build && npx wrangler pages deploy build --compatibility-date=2024-01-01",
		"debug:ios": "node check-ngrok.js",
		"debug:console": "node debug-console.js",
		"debug:console:dev": "node debug-console.js wss://mycookup-websocket-logger-dev.mycookup.workers.dev/ws",
		"debug:console:local": "node debug-console.js ws://localhost:8787/ws",
		"deploy:websocket": "./scripts/deploy-websocket-worker.sh",
		"deploy:websocket:dev": "./scripts/deploy-websocket-worker.sh development",
		"deploy:websocket:prod": "./scripts/deploy-websocket-worker.sh production",
		"deploy:websocket:local": "./scripts/deploy-websocket-worker.sh local",
		"update:websocket-urls": "node scripts/update-websocket-urls.cjs",
		"validate:websocket": "node scripts/update-websocket-urls.cjs --validate",
		"test:ios-compatibility": "node scripts/test-ios-pwa-compatibility.cjs",
		"test:capacitor": "node scripts/test-capacitor-integration.cjs",
		"validate:system": "node scripts/validate-websocket-system.cjs",
		"demo:websocket": "node test-websocket-logging-demo.cjs",
		"ngrok": "ngrok http 5173",
		"setup:ngrok": "./setup-ngrok.sh",
		"vorlon:start": "./start-vorlon-debug.sh",
		"vorlon:update": "node update-vorlon-url.js",
		"debug:vorlon": "./start-vorlon-debug.sh"
	},
	"dependencies": {
		"@capacitor/android": "^7.3.0",
		"@capacitor/app": "^7.0.1",
		"@capacitor/camera": "^7.0.1",
		"@capacitor/cli": "^7.3.0",
		"@capacitor/core": "^7.3.0",
		"@capacitor/haptics": "^7.0.1",
		"@capacitor/ios": "^7.3.0",
		"@capacitor/keyboard": "^7.0.1",
		"@capacitor/push-notifications": "^7.0.1",
		"@capacitor/status-bar": "^7.0.1",
		"@ionic/pwa-elements": "^3.3.0",
		"@preact/compat": "^18.3.1",
		"@react-router/dev": "^7.6.2",
		"preact": "^10.26.9",
		"preact-render-to-string": "^6.5.13",
		"react-router": "^7.6.2"
	},
	"devDependencies": {
		"@preact/preset-vite": "^2.10.1",
		"@tailwindcss/vite": "^4.1.4",
		"@types/node": "^20",
		"@types/react": "^19.1.8",
		"@types/ws": "^8.18.1",
		"@vitejs/plugin-basic-ssl": "^2.0.0",
		"playwright": "^1.53.0",
		"serve": "^14.2.4",
		"tailwindcss": "^4.1.4",
		"typescript": "^5.8.3",
		"vite": "^6.3.3",
		"vite-plugin-mkcert": "^1.17.8",
		"vite-tsconfig-paths": "^5.1.4",
		"vorlon": "^0.5.5",
		"wrangler": "^4.20.1",
		"ws": "^8.18.2"
	}
}
